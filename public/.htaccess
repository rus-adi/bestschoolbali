# Hostinger / Apache rules for static export (Next.js `output: export`)
# Goal: clean URLs for nested routes including multilingual paths like /id/... or /en/...

Options -MultiViews
RewriteEngine On
RewriteBase /

# 1) Always serve existing files/directories as-is.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2) If /path exists as /path.html, serve it.
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 3) If /path exists as /path/index.html, serve it
#    (works for deep and language-prefixed routes: /id/foo, /en/blog/post, etc.).
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ $1/index.html [L]

# 4) Optional fallback to generated 404 page.
RewriteRule ^ 404.html [L]
